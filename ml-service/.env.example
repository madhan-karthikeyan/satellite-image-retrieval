# SatGeoInfer Configuration
# Copy this file to .env and fill in your values

# Admin API Key (required for /index/build endpoint)
ADMIN_API_KEY=your-secure-admin-key-here

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./chroma_index

# OpenRouter API Key (optional - for LLM explanations)
# Get your key at https://openrouter.ai/
OPENROUTER_KEY=

# OpenAI-compatible API endpoint (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=
